            ],
            progress: 8,
            published: '2023-11-01',
            fileId: null,
            fileName: null,
            fileType: null,
            fileSize: null
        }, {
            id: 'book-5',
            title: 'The Silk Roads',
            subtitle: 'A New History of the World',
            author: 'Peter Frankopan',
            category: 'History',
            description: 'A groundbreaking history that reorients our understanding of world history around the Silk Roads.',
            coverEmoji: '🐫',
            chapters: [
                { id: 'ch1', title: 'The Crossroads of Civilization',
                    content: '<p>The Silk Roads were the arteries of civilization, carrying not only goods but also ideas and cultures.</p>' },
                { id: 'ch2', title: 'The Age of Empires',
