            fileType: null,
            fileSize: null
        }, {
            id: 'book-7',
            title: 'The Health Gap',
            subtitle: 'The Challenge of an Unequal World',
            author: 'Michael Marmot',
            category: 'Health',
            description: 'An exploration of the social determinants of health and the ways in which inequality shapes health outcomes.',
            coverEmoji: '❤️',
            chapters: [
                { id: 'ch1', title: 'The Social Gradient',
                    content: '<p>There is a clear social gradient in health: the higher your social position, the better your health.</p>' },
                { id: 'ch2', title: 'The Causes of Inequality',
                    content: '<p>Health inequality is the product of social and economic policies that create disadvantage.</p>' }
            ],
            progress: 12,
            published: '2024-03-18',
            fileId: null,
            fileName: null,
            fileType: null,
            fileSize: null
        }, {
            id: 'book-8',
            title: 'Nature\'s Mutiny',
            subtitle: 'How the Little Ice Age Transformed the West',
            author: 'Philipp Blom',
            category: 'Nature',
            description: 'A fascinating account of how climate change in the 16th and 17th centuries reshaped European society.',
            coverEmoji: '🌨️',
            chapters: [
                { id: 'ch1', title: 'The Little Ice Age',
                    content: '<p>The Little Ice Age was a period of cooling that affected Europe from the 14th to the 19th centuries.</p>' },
                { id: 'ch2', title: 'The Transformation of Society',
                    content: '<p>The Little Ice Age was a catalyst for social and cultural change, from the economy to religion to the arts.</p>' }
            ],
            progress: 89,
            published: '2023-12-12',
            fileId: null,
            fileName: null,
            fileType: null,
            fileSize: null
        }, {
            id: 'book-9',
            title: 'The Art of War',
            subtitle: 'Ancient Wisdom for Modern Strategy',
            author: 'Sun Tzu',
            category: 'Military',
            description: 'An enduring classic of military strategy, offering timeless insights into conflict and leadership.',
            coverEmoji: '⚔️',
            chapters: [
                { id: 'ch1', title: 'The Art of Strategy',
                    content: '<p>Strategy is the art of achieving your goals in the face of opposition.</p>' },
                { id: 'ch2', title: 'The Principles of War',
                    content: '<p>Sun Tzu laid out five fundamental principles: the moral law, heaven, earth, the commander, and method and discipline.</p>' }
            ],
            progress: 100,
            published: '2022-10-30',
            fileId: null,
            fileName: null,
            fileType: null,
            fileSize: null
        }, {
            id: 'book-10',
            title: 'The Future of Work',
            subtitle: 'AI, Automation, and the New Economy',
            author: 'Daniel Susskind',
            category: 'Technology',
            description: 'A forward-looking analysis of how AI and automation are transforming the nature of work.',
            coverEmoji: '💼',
            chapters: [
                { id: 'ch1', title: 'The Automation Revolution',
                    content: '<p>We are in the midst of a revolution in automation, with machines taking over cognitive tasks.</p>' },
                { id: 'ch2', title: 'The New Economy',
                    content: '<p>The automation revolution is creating a new economy, more productive but also more unequal.</p>' }
            ],
            progress: 55,
            published: '2024-04-22',
            fileId: null,
            fileName: null,
            fileType: null,
            fileSize: null
        }];

        // ----- STATE -------------------------------------------------------

        const STATE = {
            books: [],
            categories: [],
            currentBookId: null,
            currentCategory: 'all',
            currentPage: 'home',
            readerBookId: null,
            readerChapterIndex: 0,
            readerTheme: 'light',
            readerFontSize: 18,
            readerFontFamily: 'Georgia, "Times New Roman", serif',
            searchQuery: '',
            editingBookId: null,
            profile: {
                name: 'John Doe',
                email: 'john@booksphere.com',
                recentlyRead: [],
                bookmarks: [],
                favorites: []
            },
            fileUploadPending: null // { id, file }
        };

        // ----- DATA PERSISTENCE --------------------------------------------

        function loadData() {
            try {
                const saved = localStorage.getItem('booksphere_data');
                if (saved) {
                    const parsed = JSON.parse(saved);
                    STATE.books = parsed.books || SAMPLE_BOOKS;
                    STATE.categories = parsed.categories || [...DEFAULT_CATEGORIES];
                    STATE.profile = parsed.profile || STATE.profile;
                    STATE.books.forEach(b => {
                        if (!b.chapters) b.chapters = [];
                        if (b.progress === undefined) b.progress = 0;
                        if (!b.coverEmoji) b.coverEmoji = '📖';
                        if (b.fileId === undefined) b.fileId = null;
                        if (b.fileName === undefined) b.fileName = null;
                        if (b.fileType === undefined) b.fileType = null;
                        if (b.fileSize === undefined) b.fileSize = null;
                    });
                    return true;
                }
            } catch (e) { console.warn('Failed to load data:', e); }
            return false;
        }

        function saveData() {
            try {
                // Don't store file data in localStorage — only metadata
                const data = {
                    books: STATE.books.map(b => ({
                        ...b,
                        // file data is in IndexedDB
                    })),
                    categories: STATE.categories,
                    profile: STATE.profile
                };
                localStorage.setItem('booksphere_data', JSON.stringify(data));
            } catch (e) { console.warn('Failed to save data:', e); }
        }

        function resetData() {
            if (!confirm('Are you sure you want to reset all data? This cannot be undone.')) return;
            STATE.books = JSON.parse(JSON.stringify(SAMPLE_BOOKS));
            STATE.categories = [...DEFAULT_CATEGORIES];
            STATE.profile = {
                name: 'John Doe',
                email: 'john@booksphere.com',
                recentlyRead: [],
                bookmarks: [],
                favorites: []
            };
            STATE.editingBookId = null;
            // Clear IndexedDB files
            if (db) {
                try {
                    const tx = db.transaction(STORE_NAME, 'readwrite');
                    const store = tx.objectStore(STORE_NAME);
                    store.clear();
                } catch (e) { console.warn('Could not clear IndexedDB:', e); }
            }
            saveData();
            renderAll();
            showToast('Data reset successfully');
        }

        function exportData() {
            const data = {
                books: STATE.books,
                categories: STATE.categories,
                profile: STATE.profile,
                exported: new Date().toISOString()
            };
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `booksphere_data_${new Date().toISOString().slice(0,10)}.json`;
            a.click();
            URL.revokeObjectURL(url);
            showToast('Data exported successfully');
        }

        function importData(file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const data = JSON.parse(e.target.result);
                    if (data.books && data.categories) {
                        // Ensure file fields exist
                        data.books.forEach(b => {
                            if (b.fileId === undefined) b.fileId = null;
                            if (b.fileName === undefined) b.fileName = null;
                            if (b.fileType === undefined) b.fileType = null;
                            if (b.fileSize === undefined) b.fileSize = null;
                        });
                        STATE.books = data.books;
                        STATE.categories = data.categories;
                        if (data.profile) STATE.profile = data.profile;
                        saveData();
                        renderAll();
                        showToast('Data imported successfully');
                    } else {
                        showToast('Invalid data file');
                    }
                } catch (err) {
                    showToast('Error importing data');
                }
            };
            reader.readAsText(file);
        }

        // ----- DATA HELPERS ------------------------------------------------

        function getBook(id) {
            return STATE.books.find(b => b.id === id);
        }

        function getBooksByCategory(category) {
            if (category === 'all') return STATE.books;
            return STATE.books.filter(b => b.category === category);
        }

        function getFeaturedBooks() {
            return STATE.books.slice(0, 6);
        }

        function getRecentlyAdded() {
            return [...STATE.books].sort((a, b) =>
                new Date(b.published) - new Date(a.published)
            ).slice(0, 8);
        }

        function getRecommendedBooks() {
            const shuffled = [...STATE.books].sort(() => Math.random() - 0.5);
            return shuffled.slice(0, 6);
        }

        function generateId() {
            return 'id-' + Date.now() + '-' + Math.random().toString(36).slice(2, 6);
        }

        function getFileTypeLabel(type) {
            if (!type) return 'Unknown';
            if (type.includes('pdf')) return 'PDF';
            if (type.includes('epub')) return 'EPUB';
            if (type.includes('text')) return 'TXT';
            return type.split('/').pop() || 'File';
        }

        function getFileIcon(type) {
            if (!type) return '📄';
            if (type.includes('pdf')) return '📕';
            if (type.includes('epub')) return '📗';
            if (type.includes('text')) return '📝';
            return '📄';
        }

        function formatFileSize(bytes) {
            if (bytes < 1024) return bytes + ' B';
            if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
            return (bytes / 1048576).toFixed(1) + ' MB';
        }

        // ----- RENDER FUNCTIONS --------------------------------------------

        function renderCategories() {
            const container = document.getElementById('categoriesContainer');
            const allCategories = ['all', ...STATE.categories];
            container.innerHTML = allCategories.map(cat =>
                `<button class="category-pill ${cat === STATE.currentCategory ? 'active' : ''}"
                         data-category="${cat}"
                         role="tab"
                         aria-selected="${cat === STATE.currentCategory ? 'true' : 'false'}">
                    ${cat === 'all' ? 'All' : cat}
                </button>`
            ).join('');
        }

        function renderBookCard(book, horizontal = true) {
            const progress = book.progress || 0;
            const chapterCount = book.chapters ? book.chapters.length : 0;
            const hasFile = book.fileId !== null && book.fileId !== undefined;
            const fileType = book.fileType ? getFileTypeLabel(book.fileType) : null;

            return `
                <div class="book-card" data-book-id="${book.id}" role="article" tabindex="0">
                    <div class="cover">
                        <span class="cover-emoji">${book.coverEmoji || '📖'}</span>
                        ${hasFile ? `<span class="file-badge">${fileType || 'FILE'}</span>` : ''}
                        ${progress > 0 && progress < 100 ? `<div class="progress-ring">${Math.round(progress)}%</div>` : ''}
                        ${progress >= 100 ? `<div class="progress-ring">✓</div>` : ''}
                    </div>
                    <div class="info">
                        <div class="title">${book.title}</div>
                        <div class="author">${book.author}</div>
                        <div class="meta">
                            <span>${book.category}</span>
                            <span class="dot"></span>
                            <span>${hasFile ? '📄 ' + getFileTypeLabel(book.fileType) : chapterCount + ' chapters'}</span>
                        </div>
                        <button class="btn btn-primary btn-sm" data-action="read" data-book-id="${book.id}">
                            ${progress > 0 && progress < 100 ? 'Continue Reading' : progress >= 100 ? 'Read Again' : 'Start Reading'}
                        </button>
                    </div>
                </div>
            `;
        }

        function renderFeatured() {
            const container = document.getElementById('featuredBooks');
            const books = getFeaturedBooks();
            container.innerHTML = books.map(b => renderBookCard(b, true)).join('');
        }

        function renderRecentlyAdded() {
            const container = document.getElementById('recentlyAdded');
            const books = getRecentlyAdded();
            container.innerHTML = books.map(b => renderBookCard(b, false)).join('');
        }

        function renderRecommended() {
            const container = document.getElementById('recommendedBooks');
            const books = getRecommendedBooks();
            container.innerHTML = books.map(b => renderBookCard(b, false)).join('');
        }

        function renderBookDetail(bookId) {
            const book = getBook(bookId);
            if (!book) {
                document.getElementById('bookDetail').innerHTML = '<p>Book not found.</p>';
                return;
            }
            const progress = book.progress || 0;
            const chapterCount = book.chapters ? book.chapters.length : 0;
            const hasFile = book.fileId !== null && book.fileId !== undefined;
            const readingTime = hasFile ? '—' : Math.max(1, Math.round(chapterCount * 15));

            let fileInfoHTML = '';
            if (hasFile) {
                const fileTypeLabel = getFileTypeLabel(book.fileType);
                const fileSize = formatFileSize(book.fileSize || 0);
                const fileIcon = getFileIcon(book.fileType);
                fileInfoHTML = `
                    <div class="file-info">
                        <div class="file-details">
                            <span class="file-icon">${fileIcon}</span>
                            <span><strong>${book.fileName || 'Uploaded file'}</strong></span>
                            <span class="text-sm text-tertiary">${fileTypeLabel} · ${fileSize}</span>
                        </div>
                        <div style="display:flex;gap:8px;">
                            <button class="btn btn-sm btn-primary" data-action="download-file" data-book-id="${book.id}">⬇ Download</button>
                            <button class="btn btn-sm btn-ghost" data-action="read-file" data-book-id="${book.id}">📖 Read</button>
                        </div>
                    </div>
                `;
            }

            const html = `
                <div class="hero fade-in">
                    <div class="cover-large" style="display:flex;align-items:center;justify-content:center;font-size:5rem;position:relative;">
                        ${book.coverEmoji || '📖'}
                        ${hasFile ? `<span class="file-badge-lg">${getFileTypeLabel(book.fileType)}</span>` : ''}
                    </div>
                    <div class="details">
                        <h1>${book.title}</h1>
                        <div class="author">${book.author}</div>
                        <div class="meta-list">
                            <span>📚 ${book.category}</span>
                            <span>⏱ ${readingTime} ${hasFile ? '' : 'min read'}</span>
                            <span>${hasFile ? '📄 ' + getFileTypeLabel(book.fileType) : '📄 ' + chapterCount + ' chapters'}</span>
                        </div>
                        <div class="description">${book.description || 'No description available.'}</div>
                        <div class="actions">
                            <button class="btn btn-primary" data-action="read" data-book-id="${book.id}">
                                ${progress > 0 && progress < 100 ? 'Continue Reading' : progress >= 100 ? 'Read Again' : 'Start Reading'}
                            </button>
                            <button class="btn btn-ghost" data-action="bookmark" data-book-id="${book.id}">
                                ${STATE.profile.bookmarks.includes(book.id) ? '★ Bookmarked' : '☆ Bookmark'}
                            </button>
                            <button class="btn btn-ghost" data-action="favorite" data-book-id="${book.id}">
                                ${STATE.profile.favorites.includes(book.id) ? '❤️ Favorited' : '🤍 Favorite'}
                            </button>
                            ${hasFile ? `<button class="btn btn-ghost" data-action="download-file" data-book-id="${book.id}">⬇ Download</button>` : ''}
                            <button class="btn btn-ghost" data-action="share" data-book-id="${book.id}">↗ Share</button>
                        </div>
                    </div>
                </div>
                ${fileInfoHTML}
                ${progress > 0 ? `
                <div class="progress-section slide-up">
                    <div class="progress-label">
                        <span>Reading Progress</span>
                        <span>${Math.round(progress)}%</span>
                    </div>
                    <div class="progress-bar">
                        <div class="fill" style="width:${progress}%;"></div>
                    </div>
                </div>` : ''}
            `;
            document.getElementById('bookDetail').innerHTML = html;
        }

        function renderCategoryPage(category) {
            const title = document.getElementById('categoryTitle');
            const count = document.getElementById('categoryCount');
            const container = document.getElementById('categoryBooks');

            const books = getBooksByCategory(category);
            title.textContent = category === 'all' ? 'All Books' : category;
            count.textContent = `${books.length} book${books.length !== 1 ? 's' : ''}`;

            if (books.length === 0) {
                container.innerHTML =
                    `<p class="text-secondary" style="padding:40px 0;text-align:center;">No books in this category yet.</p>`;
                return;
            }
            container.innerHTML = books.map(b => renderBookCard(b, false)).join('');
        }

        function renderProfile() {
            const p = STATE.profile;
            document.getElementById('profileAvatar').textContent = p.name.split(' ').map(n => n[0]).join('').toUpperCase();
            document.getElementById('profileName').textContent = p.name;
            document.getElementById('profileEmail').textContent = p.email;

            const stats = document.getElementById('profileStats');
            const totalBooks = STATE.books.length;
            const readBooks = STATE.books.filter(b => b.progress >= 100).length;
            const bookmarksCount = p.bookmarks.length;
            const favoritesCount = p.favorites.length;
            stats.innerHTML = `
                <div class="stat"><div class="number">${totalBooks}</div><div class="label">Total Books</div></div>
                <div class="stat"><div class="number">${readBooks}</div><div class="label">Read</div></div>
                <div class="stat"><div class="number">${bookmarksCount}</div><div class="label">Bookmarks</div></div>
                <div class="stat"><div class="number">${favoritesCount}</div><div class="label">Favorites</div></div>
            `;

            const recentList = document.getElementById('recentlyReadList');
            const recentBooks = p.recentlyRead.slice(0, 5).map(id => getBook(id)).filter(Boolean);
            if (recentBooks.length === 0) {
                recentList.innerHTML = '<p class="text-sm text-secondary">No books read yet.</p>';
            } else {
                recentList.innerHTML = recentBooks.map(b =>
                    `<div class="item" data-book-id="${b.id}" style="cursor:pointer;">
                        <span class="emoji">${b.coverEmoji || '📖'}</span>
                        <span>${b.title}</span>
                        <span class="text-xs text-tertiary" style="margin-left:auto;">${Math.round(b.progress || 0)}%</span>
                    </div>`
                ).join('');
            }

            const bookmarksList = document.getElementById('bookmarksList');
            const bookmarks = p.bookmarks.slice(0, 5).map(id => getBook(id)).filter(Boolean);
            if (bookmarks.length === 0) {
                bookmarksList.innerHTML = '<p class="text-sm text-secondary">No bookmarks yet.</p>';
            } else {
                bookmarksList.innerHTML = bookmarks.map(b =>
                    `<div class="item" data-book-id="${b.id}" style="cursor:pointer;">
                        <span class="emoji">${b.coverEmoji || '📖'}</span>
                        <span>${b.title}</span>
                    </div>`
                ).join('');
            }

            const favoritesList = document.getElementById('favoritesList');
            const favorites = p.favorites.slice(0, 5).map(id => getBook(id)).filter(Boolean);
            if (favorites.length === 0) {
                favoritesList.innerHTML = '<p class="text-sm text-secondary">No favorites yet.</p>';
            } else {
                favoritesList.innerHTML = favorites.map(b =>
                    `<div class="item" data-book-id="${b.id}" style="cursor:pointer;">
                        <span class="emoji">${b.coverEmoji || '📖'}</span>
                        <span>${b.title}</span>
                    </div>`
                ).join('');
            }

            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            document.getElementById('darkModeToggle').classList.toggle('active', isDark);
        }

        function renderAdmin() {
            const statsContainer = document.getElementById('adminStats');
            const totalBooks = STATE.books.length;
            const totalCategories = STATE.categories.length;
            const totalChapters = STATE.books.reduce((acc, b) => acc + (b.chapters ? b.chapters.length : 0), 0);
            const totalFiles = STATE.books.filter(b => b.fileId).length;
            statsContainer.innerHTML = `
                <div class="stat"><div class="number">${totalBooks}</div><div class="label">Books</div></div>
                <div class="stat"><div class="number">${totalCategories}</div><div class="label">Categories</div></div>
                <div class="stat"><div class="number">${totalChapters}</div><div class="label">Chapters</div></div>
                <div class="stat"><div class="number">${totalFiles}</div><div class="label">Uploaded Files</div></div>
                <div class="stat"><div class="number">${STATE.books.filter(b => b.progress >= 100).length}</div><div class="label">Completed</div></div>
            `;

            const recentContainer = document.getElementById('adminRecentBooks');
            const recentBooks = STATE.books.slice(0, 5);
            if (recentBooks.length === 0) {
                recentContainer.innerHTML = '<p class="text-sm text-secondary">No books yet.</p>';
            } else {
                recentContainer.innerHTML = recentBooks.map(b =>
                    `<div class="admin-book-item">
                        <div class="cover-sm">${b.coverEmoji || '📖'}</div>
                        <div class="info">
                            <div class="title">${b.title}</div>
                            <div class="sub">${b.author} · ${b.category} ${b.fileId ? '📄' : ''}</div>
                        </div>
                        <div class="actions">
                            <button class="btn btn-sm btn-ghost" data-action="edit-book" data-book-id="${b.id}">✏️</button>
                        </div>
                    </div>`
                ).join('');
            }

            const listContainer = document.getElementById('adminBookList');
            if (STATE.books.length === 0) {
                listContainer.innerHTML = '<p class="text-sm text-secondary">No books yet. Create one in the Editor tab.</p>';
            } else {
                listContainer.innerHTML = STATE.books.map(b =>
                    `<div class="admin-book-item">
                        <div class="cover-sm">${b.coverEmoji || '📖'}</div>
                        <div class="info">
                            <div class="title">${b.title}</div>
                            <div class="sub">${b.author} · ${b.category} · ${b.fileId ? '📄 ' + getFileTypeLabel(b.fileType) : (b.chapters ? b.chapters.length : 0) + ' chapters'} · ${Math.round(b.progress || 0)}%</div>
                        </div>
                        <div class="actions">
                            <button class="btn btn-sm btn-ghost" data-action="edit-book" data-book-id="${b.id}">✏️</button>
                            <button class="btn btn-sm btn-ghost" data-action="delete-book" data-book-id="${b.id}" style="color:#FF3B30;">🗑</button>
                        </div>
                    </div>`
                ).join('');
            }

            const catContainer = document.getElementById('adminCategoryList');
            if (STATE.categories.length === 0) {
                catContainer.innerHTML = '<p class="text-sm text-secondary">No categories yet.</p>';
            } else {
                catContainer.innerHTML = STATE.categories.map(cat =>
                    `<div class="admin-book-item">
                        <div class="info"><div class="title">${cat}</div></div>
                        <div class="actions">
                            <button class="btn btn-sm btn-ghost" data-action="delete-category" data-category="${cat}" style="color:#FF3B30;">🗑</button>
                        </div>
                    </div>`
                ).join('');
            }

            const catSelect = document.getElementById('bookCategory');
            catSelect.innerHTML = STATE.categories.map(cat =>
                `<option value="${cat}">${cat}</option>`
            ).join('');

            renderEditorForm();

            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            document.getElementById('adminDarkToggle').classList.toggle('active', isDark);
        }

        function renderEditorForm() {
            const title = document.getElementById('editorTitle');
            const deleteBtn = document.getElementById('deleteBookBtn');
            const cancelBtn = document.getElementById('cancelEditBtn');
            const fileInput = document.getElementById('bookFileInput');
            const fileDisplayName = document.getElementById('fileDisplayName');
            const fileSizeDisplay = document.getElementById('fileSizeDisplay');
            const fileIcon = document.getElementById('fileIcon');
            const clearFileBtn = document.getElementById('clearFileBtn');

            if (STATE.editingBookId) {
                const book = getBook(STATE.editingBookId);
                if (book) {
                    title.textContent = `✏️ Edit Book: ${book.title}`;
                    document.getElementById('bookTitle').value = book.title || '';
                    document.getElementById('bookSubtitle').value = book.subtitle || '';
                    document.getElementById('bookAuthor').value = book.author || '';
                    document.getElementById('bookCategory').value = book.category || '';
                    document.getElementById('bookDescription').value = book.description || '';
                    document.getElementById('bookCoverEmoji').value = book.coverEmoji || '📖';
                    deleteBtn.style.display = 'inline-flex';
                    cancelBtn.style.display = 'inline-flex';

                    // Show file info if exists
                    if (book.fileId && book.fileName) {
                        fileDisplayName.textContent = book.fileName;
                        fileSizeDisplay.textContent = formatFileSize(book.fileSize || 0);
                        fileIcon.textContent = getFileIcon(book.fileType);
                        clearFileBtn.style.display = 'inline-flex';
                        fileInput.value = '';
                    } else {
                        fileDisplayName.textContent = 'No file selected';
                        fileSizeDisplay.textContent = '';
                        fileIcon.textContent = '📄';
                        clearFileBtn.style.display = 'none';
                    }

                    renderChapters(book);
                    return;
                }
            }

            // New book
            title.textContent = '✏️ Create New Book';
            document.getElementById('bookEditorForm').reset();
            document.getElementById('bookCoverEmoji').value = '📖';
            deleteBtn.style.display = 'none';
            cancelBtn.style.display = 'none';
            document.getElementById('chapterList').innerHTML = '<p class="text-sm text-secondary">No chapters yet. Add one below.</p>';
            fileDisplayName.textContent = 'No file selected';
            fileSizeDisplay.textContent = '';
            fileIcon.textContent = '📄';
            clearFileBtn.style.display = 'none';
            document.getElementById('bookFileInput').value = '';
        }

        function renderChapters(book) {
            const container = document.getElementById('chapterList');
            if (!book.chapters || book.chapters.length === 0) {
                container.innerHTML = '<p class="text-sm text-secondary">No chapters yet. Add one below.</p>';
                return;
            }
            container.innerHTML = book.chapters.map((ch, idx) =>
                `<div style="display:flex;align-items:center;gap:12px;padding:8px 0;border-bottom:1px solid var(--border);">
                    <span class="text-sm text-secondary">${idx + 1}.</span>
                    <span style="flex:1;font-weight:500;">${ch.title}</span>
                    <button class="btn btn-sm btn-ghost" data-action="edit-chapter" data-chapter-index="${idx}">✏️</button>
                    <button class="btn btn-sm btn-ghost" data-action="delete-chapter" data-chapter-index="${idx}" style="color:#FF3B30;">🗑</button>
                </div>`
            ).join('');
        }

        // ----- READING MODE (with file support) ----------------------------

        async function renderReader(bookId, chapterIndex) {
            const book = getBook(bookId);
            if (!book) {
                document.getElementById('readerContent').innerHTML = '<p>Book not found.</p>';
                return;
            }

            const hasFile = book.fileId !== null && book.fileId !== undefined;
            const contentEl = document.getElementById('readerContent');
            document.getElementById('readerBookTitle').textContent = book.title;

            if (hasFile) {
                // Try to load the file from IndexedDB
                try {
                    const fileRecord = await getFile(book.fileId);
                    if (fileRecord && fileRecord.data) {
                        const file = fileRecord.data;
                        const fileType = file.type || book.fileType || '';

                        if (fileType.includes('pdf')) {
                            // PDF: show in iframe
                            const url = URL.createObjectURL(file);
                            contentEl.innerHTML = `
                                <div style="max-width:100%;">
                                    <iframe class="pdf-viewer" src="${url}" frameborder="0" allowfullscreen></iframe>
                                    <div style="text-align:center;padding:12px 0;font-size:0.8125rem;color:var(--text-tertiary);">
                                        ${book.title} · PDF · ${formatFileSize(file.size || 0)}
                                        <button class="btn btn-sm btn-ghost" data-action="download-file" data-book-id="${book.id}" style="margin-left:12px;">⬇ Download</button>
                                    </div>
                                </div>
                            `;
                            // Clean up URL when content is replaced
                            const cleanup = () => {
                                if (url) URL.revokeObjectURL(url);
                            };
                            // We'll clean up when reader closes
                            document.getElementById('readerView')._pdfUrl = url;
                            document.getElementById('readerContent')._cleanupPdf = cleanup;
                        } else if (fileType.includes('text') || fileType.includes('plain')) {
                            // TXT: read as text
                            const text = await file.text();
                            contentEl.innerHTML = `
                                <div class="file-content-text">${escapeHtml(text)}</div>
                                <div style="text-align:center;padding:16px 0;font-size:0.8125rem;color:var(--text-tertiary);">
                                    ${book.title} · TXT · ${formatFileSize(file.size || 0)}
                                    <button class="btn btn-sm btn-ghost" data-action="download-file" data-book-id="${book.id}" style="margin-left:12px;">⬇ Download</button>
                                </div>
                            `;
                        } else {
                            // Other file types: show download prompt
                            contentEl.innerHTML = `
                                <div style="text-align:center;padding:60px 20px;">
                                    <div style="font-size:4rem;margin-bottom:20px;">${getFileIcon(fileType)}</div>
                                    <h2 style="font-weight:600;margin-bottom:8px;">${book.title}</h2>
                                    <p class="text-secondary">${getFileTypeLabel(fileType)} file (${formatFileSize(file.size || 0)})</p>
                                    <p class="text-secondary" style="margin-top:8px;">This file type cannot be previewed in the browser.</p>
                                    <button class="btn btn-primary" style="margin-top:20px;" data-action="download-file" data-book-id="${book.id}">⬇ Download File</button>
                                </div>
                            `;
                        }

                        // Update progress (for files, we mark as 100% when opened)
                        if (book.progress < 100) {
                            book.progress = 100;
                            saveData();
                        }

                        document.getElementById('readerProgress').textContent = '100%';
                        applyReaderSettings();
                        return;
                    } else {
                        // File not found in IndexedDB — fallback to chapters
                        console.warn('File not found in IndexedDB, falling back to chapters.');
                    }
                } catch (err) {
                    console.error('Error loading file:', err);
                    showToast('Error loading file. Falling back to chapters.');
                }
            }

            // Fallback: use chapters
            if (!book.chapters || book.chapters.length === 0) {
                contentEl.innerHTML = '<p>No content available for this book.</p>';
                document.getElementById('readerProgress').textContent = '0%';
                return;
            }

            if (chapterIndex >= book.chapters.length) chapterIndex = book.chapters.length - 1;
            if (chapterIndex < 0) chapterIndex = 0;

            const chapter = book.chapters[chapterIndex];
            if (!chapter) {
                contentEl.innerHTML = '<p>Chapter not found.</p>';
                return;
            }

            const total = book.chapters.length;
            document.getElementById('readerProgress').textContent =
                `${Math.round(((chapterIndex + 1) / total) * 100)}%`;

            contentEl.innerHTML = `
                <div class="chapter-title">${chapter.title}</div>
                <div class="chapter-body">${chapter.content || '<p>No content yet.</p>'}</div>
                <div style="margin-top:32px;text-align:center;font-size:0.8125rem;color:var(--text-tertiary);">
                    ${chapterIndex + 1} of ${total} · ${book.title}
                </div>
            `;
            contentEl.scrollTop = 0;

            const progress = Math.round(((chapterIndex + 1) / total) * 100);
            book.progress = Math.min(progress, 100);
            saveData();
            renderAll();

            const isBookmarked = STATE.profile.bookmarks.includes(bookId);
            document.getElementById('readerBookmark').innerHTML =
                `<svg width="18" height="18" viewBox="0 0 18 18" fill="${isBookmarked ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <path d="M4 2H14V16L9 12L4 16V2Z" />
                </svg>`;

            applyReaderSettings();
        }

        // Simple escape for HTML
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function applyReaderSettings() {
            const content = document.getElementById('readerContent');
            if (!content) return;
            content.style.fontSize = STATE.readerFontSize + 'px';
            content.style.fontFamily = STATE.readerFontFamily;

            const theme = STATE.readerTheme;
            const view = document.getElementById('readerView');
            if (theme === 'dark') {
                view.style.setProperty('--bg', '#0A0A0C');
                view.style.setProperty('--text', '#F5F5F7');
                view.style.setProperty('--text-secondary', '#AEAEB2');
                view.style.setProperty('--border', '#2C2C2E');
            } else if (theme === 'sepia') {
                view.style.setProperty('--bg', '#FBF4E8');
                view.style.setProperty('--text', '#5B4B3A');
                view.style.setProperty('--text-secondary', '#8B7A6A');
                view.style.setProperty('--border', '#E8DDD0');
            } else {
                view.style.setProperty('--bg', '#F5F5F7');
                view.style.setProperty('--text', '#1C1C1E');
                view.style.setProperty('--text-secondary', '#6E6E73');
                view.style.setProperty('--border', '#E5E5EA');
            }
            const toolbar = view.querySelector('.reader-toolbar');
            const footer = view.querySelector('.reader-footer');
            const bgColor = theme === 'dark' ? 'rgba(10,10,12,0.92)' :
                theme === 'sepia' ? 'rgba(251,244,232,0.92)' :
                'rgba(245,245,247,0.92)';
            if (toolbar) toolbar.style.background = bgColor;
            if (footer) footer.style.background = bgColor;
        }

        // ----- OPEN / CLOSE READER ----------------------------------------

        function openReader(bookId, chapterIndex = 0) {
            const book = getBook(bookId);
            if (!book) {
                showToast('Book not found.');
                return;
            }

            const hasFile = book.fileId !== null && book.fileId !== undefined;
            if (!hasFile && (!book.chapters || book.chapters.length === 0)) {
                showToast('This book has no content yet.');
                return;
            }

            STATE.readerBookId = bookId;
            STATE.readerChapterIndex = Math.min(chapterIndex, (book.chapters ? book.chapters.length : 1) - 1);

            const view = document.getElementById('readerView');
            view.classList.add('active');
            document.body.style.overflow = 'hidden';

            renderReader(bookId, STATE.readerChapterIndex);

            if (!STATE.profile.recentlyRead.includes(bookId)) {
                STATE.profile.recentlyRead.unshift(bookId);
                if (STATE.profile.recentlyRead.length > 20) STATE.profile.recentlyRead.pop();
                saveData();
            }
        }

        function closeReader() {
            // Clean up PDF URL if any
            const view = document.getElementById('readerView');
            if (view._pdfUrl) {
                URL.revokeObjectURL(view._pdfUrl);
                view._pdfUrl = null;
            }
            if (document.getElementById('readerContent')._cleanupPdf) {
                try { document.getElementById('readerContent')._cleanupPdf(); } catch (e) {}
            }

            document.getElementById('readerView').classList.remove('active');
            document.body.style.overflow = '';

            if (STATE.readerBookId) {
                const book = getBook(STATE.readerBookId);
                if (book) {
                    // For files, progress is already 100%
                    if (!book.fileId) {
                        const total = book.chapters ? book.chapters.length : 1;
                        const progress = Math.round(((STATE.readerChapterIndex + 1) / total) * 100);
                        book.progress = Math.min(progress, 100);
                    }
                    saveData();
                    renderAll();
                }
            }
            STATE.readerBookId = null;
            STATE.readerChapterIndex = 0;
        }

        function readerNext() {
            if (STATE.readerBookId === null) return;
            const book = getBook(STATE.readerBookId);
            if (!book) return;

            // If it's a file, we don't have chapters
            if (book.fileId) {
                showToast('You\'ve reached the end of the file.');
                return;
            }

            if (!book.chapters) return;
            if (STATE.readerChapterIndex + 1 < book.chapters.length) {
                STATE.readerChapterIndex++;
                renderReader(STATE.readerBookId, STATE.readerChapterIndex);
                document.getElementById('readerContent').scrollTop = 0;
            } else {
                showToast('You\'ve reached the end of the book.');
            }
        }

        function readerPrev() {
            if (STATE.readerBookId === null) return;
            const book = getBook(STATE.readerBookId);
            if (!book) return;

            if (book.fileId) {
                showToast('You\'re at the beginning of the file.');
                return;
            }

            if (STATE.readerChapterIndex > 0) {
                STATE.readerChapterIndex--;
                renderReader(STATE.readerBookId, STATE.readerChapterIndex);
                document.getElementById('readerContent').scrollTop = 0;
            } else {
                showToast('You\'re at the beginning of the book.');
            }
        }

        function toggleReaderBookmark() {
            if (STATE.readerBookId === null) return;
            const bookId = STATE.readerBookId;
            const idx = STATE.profile.bookmarks.indexOf(bookId);
            if (idx >= 0) {
                STATE.profile.bookmarks.splice(idx, 1);
                showToast('Bookmark removed');
            } else {
                STATE.profile.bookmarks.push(bookId);
                showToast('Bookmarked!');
            }
            saveData();
            renderReader(bookId, STATE.readerChapterIndex);
        }

        // ----- FILE DOWNLOAD ----------------------------------------------

        async function downloadBookFile(bookId) {
            const book = getBook(bookId);
            if (!book || !book.fileId) {
                showToast('No file available for this book.');
                return;
            }

            try {
                const fileRecord = await getFile(book.fileId);
                if (!fileRecord || !fileRecord.data) {
                    showToast('File not found in storage.');
                    return;
                }

                const file = fileRecord.data;
                const url = URL.createObjectURL(file);
                const a = document.createElement('a');
                a.href = url;
                a.download = book.fileName || `${book.title}.${file.type.split('/').pop() || 'file'}`;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                setTimeout(() => URL.revokeObjectURL(url), 5000);
                showToast(`Downloading "${book.fileName || book.title}"`);
            } catch (err) {
                console.error('Download error:', err);
                showToast('Error downloading file.');
            }
        }

        // ----- SEARCH -----------------------------------------------------

        function renderSearch(query) {
            const container = document.getElementById('searchResults');
            if (!query || query.trim().length === 0) {
                container.innerHTML = '<p class="text-sm text-secondary" style="padding:12px 0;">Type to search books, chapters, and categories.</p>';
                return;
            }

            const q = query.toLowerCase().trim();
            const results = [];

            STATE.books.forEach(book => {
                if (book.title.toLowerCase().includes(q) ||
                    book.author.toLowerCase().includes(q) ||
                    book.category.toLowerCase().includes(q) ||
                    book.description.toLowerCase().includes(q)) {
                    results.push({ type: 'book', data: book, match: book.title });
                }
                if (book.chapters) {
                    book.chapters.forEach((ch, idx) => {
                        if (ch.title.toLowerCase().includes(q) ||
                            (ch.content && ch.content.toLowerCase().includes(q))) {
                            results.push({
                                type: 'chapter',
                                data: { book, chapter: ch, index: idx },
                                match: `${book.title} · ${ch.title}`
                            });
                        }
                    });
                }
            });

            STATE.categories.forEach(cat => {
                if (cat.toLowerCase().includes(q)) {
                    results.push({ type: 'category', data: cat, match: `Category: ${cat}` });
                }
            });

            if (results.length === 0) {
                container.innerHTML = '<p class="text-sm text-secondary" style="padding:12px 0;">No results found.</p>';
                return;
            }

            container.innerHTML = results.slice(0, 20).map(r => {
                if (r.type === 'book') {
                    const b = r.data;
                    return `<div class="result-item" data-action="view-book" data-book-id="${b.id}">
                        <div class="cover-sm">${b.coverEmoji || '📖'}</div>
                        <div class="info">
                            <div class="title">${b.title}</div>
                            <div class="sub">${b.author} · ${b.category} ${b.fileId ? '📄' : ''}</div>
                        </div>
                    </div>`;
                } else if (r.type === 'chapter') {
                    const { book, chapter } = r.data;
                    return `<div class="result-item" data-action="read-chapter" data-book-id="${book.id}" data-chapter-index="${r.data.index}">
                        <div class="cover-sm">${book.coverEmoji || '📖'}</div>
                        <div class="info">
                            <div class="title">${chapter.title}</div>
                            <div class="sub">${book.title} · Chapter ${r.data.index + 1}</div>
                        </div>
                    </div>`;
                } else if (r.type === 'category') {
                    return `<div class="result-item" data-action="view-category" data-category="${r.data}">
                        <div class="cover-sm">📂</div>
                        <div class="info">
                            <div class="title">${r.data}</div>
                            <div class="sub">Category</div>
                        </div>
                    </div>`;
                }
                return '';
            }).join('');
        }

        // ----- TOAST ------------------------------------------------------

        function showToast(message) {
            const existing = document.querySelector('.toast');
            if (existing) existing.remove();

            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.textContent = message;
            document.body.appendChild(toast);
            requestAnimationFrame(() => {
                toast.classList.add('show');
            });
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 400);
            }, 2500);
        }

        // ----- NAVIGATION -------------------------------------------------

        function navigateTo(page, params) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            const target = document.getElementById(`page-${page}`);
            if (target) {
                target.classList.add('active');
                target.style.animation = 'none';
                requestAnimationFrame(() => {
                    target.style.animation = 'pageIn 0.4s ease forwards';
                });
            }
            STATE.currentPage = page;

            if (page === 'home') {
                renderAll();
            } else if (page === 'book' && params && params.bookId) {
                STATE.currentBookId = params.bookId;
                renderBookDetail(params.bookId);
            } else if (page === 'category') {
                STATE.currentCategory = params?.category || 'all';
                renderCategoryPage(STATE.currentCategory);
                document.querySelectorAll('.category-pill').forEach(pill => {
                    pill.classList.toggle('active', pill.dataset.category === STATE.currentCategory);
                });
            } else if (page === 'profile') {
                renderProfile();
            } else if (page === 'admin') {
                renderAdmin();
            }

            document.getElementById('searchOverlay').classList.remove('open');
            document.getElementById('readerView').classList.remove('active');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // ----- RENDER ALL -------------------------------------------------

        function renderAll() {
            renderCategories();
            renderFeatured();
            renderRecentlyAdded();
            renderRecommended();

            if (STATE.currentPage === 'book' && STATE.currentBookId) {
                renderBookDetail(STATE.currentBookId);
            }
            if (STATE.currentPage === 'category') {
                renderCategoryPage(STATE.currentCategory);
            }
            if (STATE.currentPage === 'profile') {
                renderProfile();
            }
            if (STATE.currentPage === 'admin') {
                renderAdmin();
            }

            const readerView = document.getElementById('readerView');
            if (readerView.classList.contains('active') && STATE.readerBookId !== null) {
                renderReader(STATE.readerBookId, STATE.readerChapterIndex);
            }
        }

        // ----- EVENT BINDING ----------------------------------------------

        function bindEvents() {
            // Category pills
            document.getElementById('categoriesContainer').addEventListener('click', function(e) {
                const pill = e.target.closest('.category-pill');
                if (!pill) return;
                const category = pill.dataset.category;
                STATE.currentCategory = category;
                navigateTo('category', { category });
            });

            // Global click delegate
            document.addEventListener('click', async function(e) {
                // Read button
                const readBtn = e.target.closest('[data-action="read"]');
                if (readBtn) {
                    const bookId = readBtn.dataset.bookId;
                    const book = getBook(bookId);
                    if (book && book.fileId) {
                        // For files, open directly
                        openReader(bookId, 0);
                    } else if (book && book.chapters && book.chapters.length > 0) {
                        const total = book.chapters.length;
                        const progress = book.progress || 0;
                        const chapterIndex = Math.min(Math.floor((progress / 100) * total), total - 1);
                        openReader(bookId, chapterIndex);
                    } else {
                        showToast('This book has no content yet.');
                    }
                    return;
                }

                // Book card click
                const card = e.target.closest('.book-card');
                if (card && !e.target.closest('[data-action]')) {
                    const bookId = card.dataset.bookId;
                    if (bookId) navigateTo('book', { bookId });
                    return;
                }

                // See all
                const seeAll = e.target.closest('.see-all');
                if (seeAll) {
                    const category = seeAll.dataset.category || 'all';
                    navigateTo('category', { category });
                    return;
                }

                // Profile toggle
                if (e.target.closest('#profileToggle')) {
                    navigateTo('profile');
                    return;
                }

                // Admin toggle
                if (e.target.closest('#adminToggle')) {
                    navigateTo('admin');
                    return;
                }

                // Nav brand
                if (e.target.closest('.nav-brand')) {
                    e.preventDefault();
                    navigateTo('home');
                    return;
                }

                // Bookmark action
                if (e.target.closest('[data-action="bookmark"]')) {
                    const btn = e.target.closest('[data-action="bookmark"]');
                    const bookId = btn.dataset.bookId;
                    const idx = STATE.profile.bookmarks.indexOf(bookId);
                    if (idx >= 0) {
                        STATE.profile.bookmarks.splice(idx, 1);
                        showToast('Bookmark removed');
                    } else {
                        STATE.profile.bookmarks.push(bookId);
                        showToast('Bookmarked!');
                    }
                    saveData();
                    if (STATE.currentPage === 'book') renderBookDetail(bookId);
                    else renderAll();
                    return;
                }

                // Favorite action
                if (e.target.closest('[data-action="favorite"]')) {
                    const btn = e.target.closest('[data-action="favorite"]');
                    const bookId = btn.dataset.bookId;
                    const idx = STATE.profile.favorites.indexOf(bookId);
                    if (idx >= 0) {
                        STATE.profile.favorites.splice(idx, 1);
                        showToast('Removed from favorites');
                    } else {
                        STATE.profile.favorites.push(bookId);
                        showToast('Added to favorites!');
                    }
                    saveData();
                    if (STATE.currentPage === 'book') renderBookDetail(bookId);
                    else renderAll();
                    return;
                }

                // Share
                if (e.target.closest('[data-action="share"]')) {
                    const bookId = e.target.closest('[data-action="share"]').dataset.bookId;
                    const book = getBook(bookId);
                    if (book && navigator.share) {
                        navigator.share({
                            title: book.title,
                            text: `Check out "${book.title}" by ${book.author} on BookSphere`,
                            url: window.location.href
                        }).catch(() => {});
                    } else if (book) {
                        navigator.clipboard.writeText(`"${book.title}" by ${book.author} — BookSphere`).then(() => {
                            showToast('Copied to clipboard!');
                        }).catch(() => {
                            showToast('Share: ' + book.title);
                        });
                    }
                    return;
                }

                // Download file
                if (e.target.closest('[data-action="download-file"]')) {
                    const btn = e.target.closest('[data-action="download-file"]');
                    const bookId = btn.dataset.bookId;
                    await downloadBookFile(bookId);
                    return;
                }

                // Read file (from file info section)
                if (e.target.closest('[data-action="read-file"]')) {
                    const btn = e.target.closest('[data-action="read-file"]');
                    const bookId = btn.dataset.bookId;
                    openReader(bookId, 0);
                    return;
                }

                // Profile list items
                const listItem = e.target.closest('.profile-sections .item');
                if (listItem && listItem.dataset.bookId) {
                    navigateTo('book', { bookId: listItem.dataset.bookId });
                    return;
                }

                // Search result items
                const resultItem = e.target.closest('.result-item');
                if (resultItem) {
                    const action = resultItem.dataset.action;
                    if (action === 'view-book' && resultItem.dataset.bookId) {
                        navigateTo('book', { bookId: resultItem.dataset.bookId });
                        document.getElementById('searchOverlay').classList.remove('open');
                    } else if (action === 'read-chapter' && resultItem.dataset.bookId) {
                        const bookId = resultItem.dataset.bookId;
                        const idx = parseInt(resultItem.dataset.chapterIndex) || 0;
                        openReader(bookId, idx);
                        document.getElementById('searchOverlay').classList.remove('open');
                    } else if (action === 'view-category' && resultItem.dataset.category) {
                        navigateTo('category', { category: resultItem.dataset.category });
                        document.getElementById('searchOverlay').classList.remove('open');
                    }
                    return;
                }

                // Admin: edit book
                const editBtn = e.target.closest('[data-action="edit-book"]');
                if (editBtn) {
                    const bookId = editBtn.dataset.bookId;
                    STATE.editingBookId = bookId;
                    document.querySelector('[data-admin-tab="editor"]').click();
                    renderEditorForm();
                    const book = getBook(bookId);
                    if (book) {
                        document.getElementById('bookTitle').value = book.title || '';
                        document.getElementById('bookSubtitle').value = book.subtitle || '';
                        document.getElementById('bookAuthor').value = book.author || '';
                        document.getElementById('bookCategory').value = book.category || '';
                        document.getElementById('bookDescription').value = book.description || '';
                        document.getElementById('bookCoverEmoji').value = book.coverEmoji || '📖';
                        if (book.fileId && book.fileName) {
                            document.getElementById('fileDisplayName').textContent = book.fileName;
                            document.getElementById('fileSizeDisplay').textContent = formatFileSize(book.fileSize || 0);
                            document.getElementById('fileIcon').textContent = getFileIcon(book.fileType);
                            document.getElementById('clearFileBtn').style.display = 'inline-flex';
                        }
                        renderChapters(book);
                        document.getElementById('editorTitle').textContent = `✏️ Edit Book: ${book.title}`;
                        document.getElementById('deleteBookBtn').style.display = 'inline-flex';
                        document.getElementById('cancelEditBtn').style.display = 'inline-flex';
                    }
                    return;
                }

                // Admin: delete book
                const deleteBookBtn = e.target.closest('[data-action="delete-book"]');
                if (deleteBookBtn) {
                    const bookId = deleteBookBtn.dataset.bookId;
                    const book = getBook(bookId);
                    if (!book) return;
                    if (!confirm(`Delete "${book.title}" permanently?`)) return;
                    // Delete file from IndexedDB if exists
                    if (book.fileId) {
                        try { await deleteFile(book.fileId); } catch (e) { console.warn('Could not delete file:', e); }
                    }
                    STATE.books = STATE.books.filter(b => b.id !== bookId);
                    STATE.profile.bookmarks = STATE.profile.bookmarks.filter(id => id !== bookId);
                    STATE.profile.favorites = STATE.profile.favorites.filter(id => id !== bookId);
                    STATE.profile.recentlyRead = STATE.profile.recentlyRead.filter(id => id !== bookId);
                    saveData();
                    renderAll();
                    renderAdmin();
                    showToast('Book deleted.');
                    return;
                }

                // Admin: delete category
                const deleteCatBtn = e.target.closest('[data-action="delete-category"]');
                if (deleteCatBtn) {
                    const category = deleteCatBtn.dataset.category;
                    if (!category) return;
                    const used = STATE.books.some(b => b.category === category);
                    if (used) {
                        showToast(`Cannot delete "${category}" — used by ${STATE.books.filter(b => b.category === category).length} book(s).`);
                        return;
                    }
                    if (!confirm(`Delete category "${category}"?`)) return;
                    STATE.categories = STATE.categories.filter(c => c !== category);
                    saveData();
                    renderAll();
                    renderAdmin();
                    showToast('Category deleted.');
                    return;
                }
            });

            // --- Search ---
            document.getElementById('searchToggle').addEventListener('click', function() {
                const overlay = document.getElementById('searchOverlay');
                overlay.classList.toggle('open');
                if (overlay.classList.contains('open')) {
                    document.getElementById('searchInput').focus();
                }
            });
            document.getElementById('closeSearch').addEventListener('click', function() {
                document.getElementById('searchOverlay').classList.remove('open');
            });
            document.getElementById('searchOverlay').addEventListener('click', function(e) {
                if (e.target === this) this.classList.remove('open');
            });
            document.getElementById('searchInput').addEventListener('input', function() {
                renderSearch(this.value);
            });
            document.getElementById('searchInput').addEventListener('keydown', function(e) {
                if (e.key === 'Escape') document.getElementById('searchOverlay').classList.remove('open');
            });

            // --- Reader controls ---
            document.getElementById('readerClose').addEventListener('click', closeReader);
            document.getElementById('readerNext').addEventListener('click', readerNext);
            document.getElementById('readerPrev').addEventListener('click', readerPrev);
            document.getElementById('readerBookmark').addEventListener('click', toggleReaderBookmark);

            document.addEventListener('keydown', function(e) {
                const readerActive = document.getElementById('readerView').classList.contains('active');
                if (!readerActive) return;
                if (e.key === 'Escape') { closeReader();
                    e.preventDefault(); } else if (e.key === 'ArrowRight' || e.key === ' ') { e.preventDefault();
                    readerNext(); } else if (e.key === 'ArrowLeft') { e.preventDefault();
                    readerPrev(); } else if (e.key === 'b' || e.key === 'B') { toggleReaderBookmark(); }
            });

            // Reader settings
            document.getElementById('readerSettingsToggle').addEventListener('click', function() {
                document.getElementById('readerSettings').classList.toggle('open');
            });
            document.addEventListener('click', function(e) {
                const settings = document.getElementById('readerSettings');
                const toggle = document.getElementById('readerSettingsToggle');
                if (!settings.contains(e.target) && !toggle.contains(e.target)) {
                    settings.classList.remove('open');
                }
            });
            document.getElementById('readerFontSize').addEventListener('input', function() {
                STATE.readerFontSize = parseInt(this.value);
                applyReaderSettings();
            });
            document.getElementById('readerFontFamily').addEventListener('change', function() {
                STATE.readerFontFamily = this.value;
                applyReaderSettings();
            });
            document.querySelectorAll('.reader-theme-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('.reader-theme-btn').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    STATE.readerTheme = this.dataset.theme;
                    applyReaderSettings();
                });
            });

            // --- Dark mode ---
            function toggleDarkMode() {
                const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
                if (isDark) {
                    document.documentElement.removeAttribute('data-theme');
                } else {
                    document.documentElement.setAttribute('data-theme', 'dark');
                }
                document.querySelectorAll('.toggle').forEach(t => t.classList.toggle('active', !isDark));
                localStorage.setItem('booksphere_dark', !isDark ? 'true' : 'false');
            }
            document.getElementById('darkModeToggle').addEventListener('click', toggleDarkMode);
            document.getElementById('darkModeToggle').addEventListener('keydown', function(e) {
                if (e.key === 'Enter' || e.key === ' ') { e.preventDefault();
                    toggleDarkMode(); }
            });
            document.getElementById('adminDarkToggle').addEventListener('click', toggleDarkMode);
            document.getElementById('adminDarkToggle').addEventListener('keydown', function(e) {
                if (e.key === 'Enter' || e.key === ' ') { e.preventDefault();
                    toggleDarkMode(); }
            });

            // --- Admin navigation ---
            document.querySelectorAll('[data-admin-tab]').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('[data-admin-tab]').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    const tab = this.dataset.adminTab;
                    document.querySelectorAll('.admin-section').forEach(s => s.classList.remove('active'));
                    const target = document.getElementById(`admin-${tab}`);
                    if (target) target.classList.add('active');
                });
            });

            // --- Admin: Add chapter ---
            document.getElementById('addChapterBtn').addEventListener('click', function() {
                const bookId = STATE.editingBookId;
                if (!bookId) {
                    showToast('Please save the book first before adding chapters.');
                    return;
                }
                const book = getBook(bookId);
                if (!book) return;
                if (book.fileId) {
                    showToast('This book has an uploaded file. Chapters are not used for file-based books.');
                    return;
                }
                const title = prompt('Enter chapter title:');
                if (title === null) return;
                if (title.trim() === '') { showToast('Chapter title cannot be empty.'); return; }
                const content = prompt('Enter chapter content (HTML supported):', '<p>Your chapter content here.</p>');
                if (content === null) return;
                book.chapters.push({ id: generateId(), title: title.trim(), content: content || '<p>Content coming soon.</p>' });
                saveData();
                renderChapters(book);
                renderAll();
                showToast('Chapter added!');
            });

            // --- Admin: Chapter actions ---
            document.getElementById('chapterList').addEventListener('click', function(e) {
                const editBtn = e.target.closest('[data-action="edit-chapter"]');
                if (editBtn) {
                    const idx = parseInt(editBtn.dataset.chapterIndex);
                    const bookId = STATE.editingBookId;
                    if (!bookId) return;
                    const book = getBook(bookId);
                    if (!book || !book.chapters || idx >= book.chapters.length) return;
                    const ch = book.chapters[idx];
                    const newTitle = prompt('Edit chapter title:', ch.title);
                    if (newTitle === null) return;
                    const newContent = prompt('Edit chapter content (HTML):', ch.content);
                    if (newContent === null) return;
                    ch.title = newTitle.trim() || ch.title;
                    ch.content = newContent || ch.content;
                    saveData();
                    renderChapters(book);
                    renderAll();
                    showToast('Chapter updated!');
                    return;
                }
                const deleteBtn = e.target.closest('[data-action="delete-chapter"]');
                if (deleteBtn) {
                    const idx = parseInt(deleteBtn.dataset.chapterIndex);
                    const bookId = STATE.editingBookId;
                    if (!bookId) return;
                    const book = getBook(bookId);
                    if (!book || !book.chapters || idx >= book.chapters.length) return;
                    if (!confirm(`Delete chapter "${book.chapters[idx].title}"?`)) return;
                    book.chapters.splice(idx, 1);
                    saveData();
                    renderChapters(book);
                    renderAll();
                    showToast('Chapter deleted.');
                }
            });

            // --- Admin: File upload ---
            const fileInput = document.getElementById('bookFileInput');
            const fileDisplayName = document.getElementById('fileDisplayName');
            const fileSizeDisplay = document.getElementById('fileSizeDisplay');
            const fileIcon = document.getElementById('fileIcon');
            const clearFileBtn = document.getElementById('clearFileBtn');
            const fileWrapper = document.getElementById('fileUploadWrapper');

            fileInput.addEventListener('change', function(e) {
                if (this.files && this.files.length > 0) {
                    const file = this.files[0];
                    const maxSize = 50 * 1024 * 1024; // 50MB
                    if (file.size > maxSize) {
                        showToast('File is too large (max 50MB).');
                        this.value = '';
                        return;
                    }
                    fileDisplayName.textContent = file.name;
                    fileSizeDisplay.textContent = formatFileSize(file.size);
                    fileIcon.textContent = getFileIcon(file.type);
                    clearFileBtn.style.display = 'inline-flex';
                    // Store file temporarily
                    STATE.fileUploadPending = { file };
                } else {
                    fileDisplayName.textContent = 'No file selected';
                    fileSizeDisplay.textContent = '';
                    fileIcon.textContent = '📄';
                    clearFileBtn.style.display = 'none';
                    STATE.fileUploadPending = null;
                }
            });

            fileWrapper.addEventListener('click', function(e) {
                if (e.target.tagName !== 'BUTTON' && e.target.closest('.btn') === null) {
                    fileInput.click();
                }
            });

            clearFileBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                fileInput.value = '';
                fileDisplayName.textContent = 'No file selected';
                fileSizeDisplay.textContent = '';
                fileIcon.textContent = '📄';
                clearFileBtn.style.display = 'none';
                STATE.fileUploadPending = null;
                // Remove file from book if editing
                if (STATE.editingBookId) {
                    const book = getBook(STATE.editingBookId);
                    if (book && book.fileId) {
                        // We'll clear it on save
                        book.fileId = null;
                        book.fileName = null;
                        book.fileType = null;
                        book.fileSize = null;
                        saveData();
                    }
                }
            });

            // --- Admin: Book form ---
            document.getElementById('bookEditorForm').addEventListener('submit', async function(e) {
                e.preventDefault();

                const title = document.getElementById('bookTitle').value.trim();
                const subtitle = document.getElementById('bookSubtitle').value.trim();
                const author = document.getElementById('bookAuthor').value.trim();
                const category = document.getElementById('bookCategory').value;
                const description = document.getElementById('bookDescription').value.trim();
                const coverEmoji = document.getElementById('bookCoverEmoji').value.trim() || '📖';

                if (!title || !author) {
                    showToast('Title and author are required.');
                    return;
                }

                const bookId = STATE.editingBookId;
                let fileId = null;
                let fileName = null;
                let fileType = null;
                let fileSize = null;

                // Handle file upload
                if (STATE.fileUploadPending && STATE.fileUploadPending.file) {
                    const file = STATE.fileUploadPending.file;
                    fileId = generateId();
                    fileName = file.name;
                    fileType = file.type || 'application/octet-stream';
                    fileSize = file.size;
                    try {
                        await storeFile(fileId, file);
                        showToast('File uploaded successfully!');
                    } catch (err) {
                        showToast('Error uploading file: ' + err.message);
                        return;
                    }
                }

                if (bookId) {
                    const book = getBook(bookId);
                    if (book) {
                        // If a new file was uploaded, delete the old one
                        if (fileId && book.fileId) {
                            try { await deleteFile(book.fileId); } catch (e) { console.warn('Could not delete old file:', e); }
                        }
                        book.title = title;
                        book.subtitle = subtitle;
                        book.author = author;
                        book.category = category;
                        book.description = description;
                        book.coverEmoji = coverEmoji;
                        if (fileId) {
                            book.fileId = fileId;
                            book.fileName = fileName;
                            book.fileType = fileType;
                            book.fileSize = fileSize;
                        } else if (book.fileId && !fileId) {
                            // If file was cleared, we keep the existing file
                            // but if user cleared via clear button, it's already handled
                            // If they want to remove, they need to use clear button
                        }
                        saveData();
                        showToast('Book updated!');
                        STATE.editingBookId = null;
                        STATE.fileUploadPending = null;
                        renderAll();
                        renderAdmin();
                        document.querySelector('[data-admin-tab="books"]').click();
                    }
                } else {
                    const newBook = {
                        id: generateId(),
                        title,
                        subtitle,
                        author,
                        category,
                        description,
                        coverEmoji,
                        chapters: [],
                        progress: 0,
                        published: new Date().toISOString().slice(0, 10),
                        fileId: fileId || null,
                        fileName: fileName || null,
                        fileType: fileType || null,
                        fileSize: fileSize || null
                    };
                    STATE.books.push(newBook);
                    saveData();
                    showToast('Book created!');
                    STATE.editingBookId = null;
                    STATE.fileUploadPending = null;
                    renderAll();
                    renderAdmin();
                    document.querySelector('[data-admin-tab="books"]').click();
                }

                document.getElementById('bookEditorForm').reset();
                document.getElementById('bookCoverEmoji').value = '📖';
                document.getElementById('editorTitle').textContent = '✏️ Create New Book';
                document.getElementById('deleteBookBtn').style.display = 'none';
                document.getElementById('cancelEditBtn').style.display = 'none';
                document.getElementById('chapterList').innerHTML = '<p class="text-sm text-secondary">No chapters yet. Add one below.</p>';
                document.getElementById('fileDisplayName').textContent = 'No file selected';
                document.getElementById('fileSizeDisplay').textContent = '';
                document.getElementById('fileIcon').textContent = '📄';
                document.getElementById('clearFileBtn').style.display = 'none';
                STATE.editingBookId = null;
            });

            // --- Admin: Cancel edit ---
            document.getElementById('cancelEditBtn').addEventListener('click', function() {
                STATE.editingBookId = null;
                STATE.fileUploadPending = null;
                document.getElementById('bookEditorForm').reset();
                document.getElementById('bookCoverEmoji').value = '📖';
                document.getElementById('editorTitle').textContent = '✏️ Create New Book';
                document.getElementById('deleteBookBtn').style.display = 'none';
                document.getElementById('cancelEditBtn').style.display = 'none';
                document.getElementById('chapterList').innerHTML = '<p class="text-sm text-secondary">No chapters yet. Add one below.</p>';
                document.getElementById('fileDisplayName').textContent = 'No file selected';
                document.getElementById('fileSizeDisplay').textContent = '';
                document.getElementById('fileIcon').textContent = '📄';
                document.getElementById('clearFileBtn').style.display = 'none';
                document.querySelector('[data-admin-tab="books"]').click();
            });

            // --- Admin: Delete book from editor ---
            document.getElementById('deleteBookBtn').addEventListener('click', async function() {
                const bookId = STATE.editingBookId;
                if (!bookId) return;
                const book = getBook(bookId);
                if (!book) return;
                if (!confirm(`Delete "${book.title}" permanently? This cannot be undone.`)) return;
                if (book.fileId) {
                    try { await deleteFile(book.fileId); } catch (e) { console.warn('Could not delete file:', e); }
                }
                STATE.books = STATE.books.filter(b => b.id !== bookId);
                STATE.profile.bookmarks = STATE.profile.bookmarks.filter(id => id !== bookId);
                STATE.profile.favorites = STATE.profile.favorites.filter(id => id !== bookId);
                STATE.profile.recentlyRead = STATE.profile.recentlyRead.filter(id => id !== bookId);
                STATE.editingBookId = null;
                STATE.fileUploadPending = null;
                saveData();
                renderAll();
                renderAdmin();
                document.getElementById('bookEditorForm').reset();
                document.getElementById('bookCoverEmoji').value = '📖';
                document.getElementById('editorTitle').textContent = '✏️ Create New Book';
                document.getElementById('deleteBookBtn').style.display = 'none';
                document.getElementById('cancelEditBtn').style.display = 'none';
                document.getElementById('chapterList').innerHTML = '<p class="text-sm text-secondary">No chapters yet. Add one below.</p>';
                document.getElementById('fileDisplayName').textContent = 'No file selected';
                document.getElementById('fileSizeDisplay').textContent = '';
                document.getElementById('fileIcon').textContent = '📄';
                document.getElementById('clearFileBtn').style.display = 'none';
                document.querySelector('[data-admin-tab="books"]').click();
                showToast('Book deleted.');
            });

            // --- Admin: Add category ---
            document.getElementById('addCategoryBtn').addEventListener('click', function() {
                const input = document.getElementById('newCategoryInput');
                const name = input.value.trim();
                if (!name) { showToast('Please enter a category name.'); return; }
                if (STATE.categories.includes(name)) { showToast('Category already exists.'); return; }
                STATE.categories.push(name);
                saveData();
                renderAll();
                renderAdmin();
                input.value = '';
                showToast(`Category "${name}" added.`);
            });

            // --- Admin: Export / Import / Reset ---
            document.getElementById('exportDataBtn').addEventListener('click', exportData);
            document.getElementById('importDataBtn').addEventListener('click', function() {
                document.getElementById('importFileInput').click();
            });
            document.getElementById('importFileInput').addEventListener('change', function(e) {
                if (this.files && this.files.length > 0) {
                    importData(this.files[0]);
                    this.value = '';
                }
            });
            document.getElementById('resetDataBtn').addEventListener('click', resetData);

            // --- Keyboard shortcuts ---
            document.addEventListener('keydown', function(e) {
                if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
                    e.preventDefault();
                    const overlay = document.getElementById('searchOverlay');
                    overlay.classList.toggle('open');
                    if (overlay.classList.contains('open')) {
                        document.getElementById('searchInput').focus();
                    }
                }
                if (e.key === 'Escape') {
                    if (document.getElementById('searchOverlay').classList.contains('open')) {
                        document.getElementById('searchOverlay').classList.remove('open');
                    }
                }
            });
        }

        // ----- INIT -------------------------------------------------------

        async function init() {
            // Open IndexedDB
            try {
                await openDB();
                console.log('📦 IndexedDB ready');
            } catch (e) {
                console.warn('IndexedDB not available:', e);
            }

            if (!loadData()) {
                STATE.books = JSON.parse(JSON.stringify(SAMPLE_BOOKS));
                STATE.categories = [...DEFAULT_CATEGORIES];
                saveData();
            }

            const darkPref = localStorage.getItem('booksphere_dark');
            if (darkPref === 'true') {
                document.documentElement.setAttribute('data-theme', 'dark');
                document.querySelectorAll('.toggle').forEach(t => t.classList.add('active'));
            }

            bindEvents();
            renderAll();
            navigateTo('home');

            setTimeout(() => {
                showToast('📚 BookSphere ready — upload, read, and download books.');
            }, 600);

            console.log(`📚 BookSphere initialized with ${STATE.books.length} books, ${STATE.categories.length} categories`);
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
    </script>
</body>
</html>
